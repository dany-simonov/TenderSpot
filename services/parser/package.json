{
  "name": "@tenderspot/parser",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "tsx src/index.ts --once & python scripts/job_report.py",
    "dev": "tsx src/index.ts --once",
    "run": "npm run start",
    "schedule": "tsx src/index.ts",
    "server": "tsx src/server.ts",
    "dev:server": "tsx src/server.ts",
    "clear": "tsx src/utils/clear-db.ts",
    "db:ensure-isviewed": "tsx src/utils/ensure-isviewed-attribute.ts",
    "debug:discover": "tsx src/utils/debug-5-tenders.ts",
    "build": "esbuild src/run.ts --bundle --platform=node --target=node18 --format=cjs --packages=external --outfile=dist/index.js",
    "report:docx": "python scripts/job_report.py"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^5.3.0",
    "node-appwrite": "^23.1.0",
    "node-cron": "^4.2.1",
    "sax": "^1.4.1",
    "vite_react_shadcn_ts": "file:../..",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/sax": "^1.2.7",
    "esbuild": "^0.23.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
